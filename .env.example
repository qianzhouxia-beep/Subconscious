# Zeabur 环境变量配置模板
# 在 Zeabur 控制台 → Service → Environment Variables 中配置
# 或通过 zeabur.json / zeabur.toml 声明

# === 必需配置（至少配置一个 AI 模型） ===
# FLASK_ENV=production
# DEEPSEEK_API_KEY=sk-xxxxxxxx          # 主模型：DeepSeek V4（推荐）
# 注意：旧模型 ID deepseek-chat / deepseek-reasoner 将于 2026/07/24 到期
#       代码已自动切换到 deepseek-v4-flash / deepseek-v4-pro
# OPENAI_API_KEY=sk-proj-xxxxxxxx       # 备用模型 1：OpenAI（推荐配置，作为 DeepSeek 的容灾）

# === DeepSeek V4 模型选择（可选） ===
# 默认可满足大部分场景，以下变量仅在需要覆盖时配置
# DEEPSEEK_CHAT_MODEL=deepseek-v4-flash    # 问答/符号/语音清理使用（更快更便宜）
# DEEPSEEK_REPORT_MODEL=deepseek-v4-pro    # 命运报告使用（更强推理，带 Thinking 链式思维）

# === AI 模型备用链路（可选，进一步增加可靠性） ===
# 第二备用：任意 OpenAI 兼容 API（可接入 Moonshot/Kimi/Qwen/GLM 等）
# FALLBACK_API_KEY=sk-xxxxxxxx
# FALLBACK_API_BASE=https://api.moonshot.cn/v1/chat/completions
# FALLBACK_MODEL=moonshot-v1-8k

# === 支付配置 ===
# PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_SECRET=your-paypal-secret
# PAYPAL_WEBHOOK_ID=your-webhook-id

# === 邮件配置（飞书 SMTP）===
# SMTP_HOST=smtp.larksuite.com
# SMTP_PORT=465
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-pass

# === 品牌配置 ===
# BASE_URL=https://your-app.zeabur.app

# === 可选配置 ===
# ENABLE_TEST_MODE=0
# CORS_ORIGINS=https://your-app.zeabur.app
# LOG_LEVEL=info
# GUNICORN_WORKERS=2
# WHISPER_API_BASE=https://api-tokenmaster.com/v1/audio/transcriptions
# WHISPER_API_KEY=your-whisper-key
# GUMROAD_PERMALINK=subconscious-mirror
# LOGO_URL=https://raw.githubusercontent.com/qianzhouxia-beep/Subconscious/main/static/logo.png
