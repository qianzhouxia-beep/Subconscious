# Zeabur 环境变量配置模板
# 在 Zeabur 控制台 → Service → Environment Variables 中配置
# 或通过 zeabur.json / zeabur.toml 声明

# === 必需配置 ===
# FLASK_ENV=production
# DEEPSEEK_API_KEY=sk-xxxxxxxx

# === 支付配置 ===
# PAYPAL_CLIENT_ID=your-paypal-client-id
# PAYPAL_SECRET=your-paypal-secret
# PAYPAL_WEBHOOK_ID=your-webhook-id

# === 邮件配置（飞书 SMTP）===
# SMTP_HOST=smtp.larksuite.com
# SMTP_PORT=465
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-pass

# === 品牌配置 ===
# BASE_URL=https://your-app.zeabur.app

# === 可选配置 ===
# ENABLE_TEST_MODE=0
# CORS_ORIGINS=https://your-app.zeabur.app
# LOG_LEVEL=info
# GUNICORN_WORKERS=2
# WHISPER_API_BASE=https://api-tokenmaster.com/v1/audio/transcriptions
# WHISPER_API_KEY=your-whisper-key
# GUMROAD_PERMALINK=subconscious-mirror
# LOGO_URL=https://raw.githubusercontent.com/qianzhouxia-beep/Subconscious/main/static/logo.png
